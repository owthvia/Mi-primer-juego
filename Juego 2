<!DOCTYPE html>
<html>
<head>
  <title>Juego de Matemáticas</title>
  <style>
    body {
      font-family: Arial;
      text-align: center;
      background: #222;
      color: white;
    }

    #game {
      margin-top: 50px;
    }

    input, button {
      padding: 10px;
      font-size: 18px;
      margin: 10px;
    }
  </style>
</head>
<body>

<h1>Juego de Matemáticas 🧠</h1>
<div id="game"></div>

<script>
let nivel = 1;

function cargarNivel() {
  const game = document.getElementById("game");

  if (nivel === 1) {
    game.innerHTML = nivelHTML("5 + 3", 1);
  }

  if (nivel === 2) {
    game.innerHTML = nivelHTML("12 - 4", 2);
  }

  if (nivel === 3) {
    game.innerHTML = nivelHTML("6 × 3", 3);
  }

  if (nivel === 4) {
    game.innerHTML = nivelHTML("20 ÷ 4", 4);
  }

  if (nivel === 5) {
    game.innerHTML = nivelHTML("15 + 6 - 3", 5);
  }

  if (nivel === 6) {
    game.innerHTML = nivelHTML("8 × 2 + 4", 6);
  }

  if (nivel === 7) {
    game.innerHTML = nivelHTML("30 ÷ 5 + 7", 7);
  }

  if (nivel === 8) {
    game.innerHTML = nivelHTML("10 + 5 × 2", 8);
  }

  if (nivel === 9) {
    game.innerHTML = nivelHTML("(6 + 4) × 2", 9);
  }

  if (nivel === 10) {
    game.innerHTML = nivelHTML("50 ÷ (5 + 5)", 10);
  }

  if (nivel > 10) {
    game.innerHTML = "<h2>🎉 ¡Ganaste todo el juego!</h2>";
  }
}

function nivelHTML(pregunta, nivelActual) {
  return `
    <h2>Nivel ${nivelActual}</h2>
    <p>Resuelve: ${pregunta}</p>
    <input id="respuesta">
    <br>
    <button onclick="verificar(${nivelActual})">Responder</button>
  `;
}

function verificar(n) {
  const r = document.getElementById("respuesta").value;

  const respuestas = {
    1: 8,
    2: 8,
    3: 18,
    4: 5,
    5: 18,
    6: 20,
    7: 13,
    8: 20,
    9: 20,
    10: 5
  };

  if (r == respuestas[n]) {
    alert("✅ Correcto");
    nivel++;
    cargarNivel();
  } else {
    alert("❌ Incorrecto, intenta otra vez");
  }
}

cargarNivel();
</script>

</body>
</html>
