<!DOCTYPE html>
<html>
<head>
  <title>Juego de Pensar</title>
  <style>
    body {
      font-family: Arial;
      text-align: center;
      background: #111;
      color: white;
    }
    button {
      padding: 10px 20px;
      font-size: 16px;
      margin-top: 10px;
    }
    input {
      padding: 8px;
      font-size: 16px;
    }
  </style>
</head>
<body>

<h1>Juego de Pensar 🧠</h1>
<h2 id="nivel">Nivel 1</h2>
<p id="pregunta"></p>

<input type="text" id="respuesta" placeholder="Escribe tu respuesta">
<br>
<button onclick="verificar()">Responder</button>

<p id="mensaje"></p>

<script>
let nivelActual = 0;

const niveles = [
  { pregunta: "¿Cuánto es 2 + 2?", respuesta: "4" },
  { pregunta: "Si tienes 3 manzanas y comes 1, ¿cuántas quedan?", respuesta: "2" },
  { pregunta: "¿Qué número falta? 2, 4, 6, ?", respuesta: "8" },
  { pregunta: "¿Cuánto es 5 x 3?", respuesta: "15" },
  { pregunta: "Un triángulo tiene cuántos lados?", respuesta: "3" },
  { pregunta: "¿Cuánto es 10 / 2?", respuesta: "5" },
  { pregunta: "¿Qué número sigue? 1, 1, 2, 3, 5, ?", respuesta: "8" },
  { pregunta: "¿Cuánto es 9 - 4?", respuesta: "5" },
  { pregunta: "¿Cuánto es 6 + 7?", respuesta: "13" },
  { pregunta: "Nivel final: escribe la palabra 'ganar'", respuesta: "ganar" }
];

function cargarNivel() {
  document.getElementById("nivel").textContent = "Nivel " + (nivelActual + 1);
  document.getElementById("pregunta").textContent = niveles[nivelActual].pregunta;
}

function verificar() {
  const respuestaUsuario = document.getElementById("respuesta").value.toLowerCase();

  if (respuestaUsuario === niveles[nivelActual].respuesta) {
    nivelActual++;

    if (nivelActual === niveles.length) {
      document.body.innerHTML = "<h1>🎉 ¡Ganaste el juego!</h1>";
      return;
    }

    document.getElementById("mensaje").textContent = "¡Correcto! Pasas al siguiente nivel.";
    document.getElementById("respuesta").value = "";
    cargarNivel();
  } else {
    document.getElementById("mensaje").textContent = "Incorrecto, intenta otra vez.";
  }
}

cargarNivel();
</script>

</body>
</html>
